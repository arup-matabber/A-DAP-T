# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Firebase Configuration
# Option 1: full service account JSON as one environment variable.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option 2: service account JSON file path for local development only.
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Option 3: individual service account fields.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Web API Key. Required only if using backend /auth/login.
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
